# LLM API Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek (if using Pro endpoint)
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://pro.deepseek.com

# Alternative endpoints (customize as needed)
# ANTHROPIC_API_KEY=your-anthropic-api-key
# CUSTOM_LLM_API_KEY=your-custom-api-key
# CUSTOM_LLM_BASE_URL=https://your-custom-endpoint.com/v1
